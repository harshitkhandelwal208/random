# ─────────────────────────────────────────────
# Discord Birthday Bot — Environment Variables
# Rename this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# Discord user ID to ping (right-click user → Copy User ID)
BIRTHDAY_USER_ID=123456789012345678

# Channel ID to send messages in (right-click channel → Copy Channel ID)
CHANNEL_ID=987654321098765432

# How often to send a ping, in seconds (default: 15)
PING_INTERVAL=15

# Gemini API key for AI-generated messages (optional)
# Get one free at https://aistudio.google.com/apikey
# If omitted, the bot falls back to hardcoded messages
GEMINI_API_KEY=AIza...
